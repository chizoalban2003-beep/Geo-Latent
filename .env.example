# geo-latent environment template
# Copy to .env and fill in real values before running.
# NEVER commit .env to source control.

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://geolatent:geolatent@localhost:5432/geolatent
DB_POOL_MAX=10

# ── Redis (optional) ──────────────────────────────────────────────────────
GEOLATENT_REDIS_URL=redis://localhost:6379/0

# ── Core secrets — MUST be rotated before production ─────────────────────
# Generate with: openssl rand -hex 32
GEOLATENT_JWT_SECRET=changeme
GEOLATENT_AUDIT_SIGNING_KEY=changeme
GEOLATENT_BUNDLE_SECRET=changeme

# ── Auth ──────────────────────────────────────────────────────────────────
# Dev header auth — NEVER true in production
GEOLATENT_ALLOW_HEADER_DEV=false

# OIDC provider (Clerk, Auth0, Cognito) for RS256 JWT verification
# Example (Clerk): https://your-app.clerk.accounts.dev/.well-known/jwks.json
GEOLATENT_OIDC_JWKS_URI=

# Token TTL in seconds (default: 86400 = 24 hours)
GEOLATENT_TOKEN_TTL=86400

# ── Stripe billing ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_RESEARCH=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_ENTERPRISE=

# ── LLM biome lore (optional — fallback to procedural lore if unset) ──────
ANTHROPIC_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated. Use * for open access (dev only)
CORS_ORIGINS=*

# ── Public URL (used by Stripe redirect and SDK schema) ───────────────────
# Set to your deployment URL in production, e.g. https://myapp.railway.app
GEOLATENT_PUBLIC_URL=http://localhost:8001

# ── Runtime mode ─────────────────────────────────────────────────────────
# demo     — no DB required, studio tier unlocked, relaxed validation
# dev      — same as demo but with verbose logging
# production — requires DATABASE_URL, enforces tier gates, RS256 sig check
GEOLATENT_MODE=production

# ── Default simulation scenario ───────────────────────────────────────────
GEOLATENT_DEFAULT_SCENARIO=neutral_baseline
