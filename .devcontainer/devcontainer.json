{
  "name": "Geo-latent v3.0",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {"version": "20"},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [8000, 5432, 6379],
  "portsAttributes": {
    "8000": {"label": "Geo-latent API + Viewer", "onAutoForward": "openBrowser"},
    "5432": {"label": "Postgres"},
    "6379": {"label": "Redis"}
  },
  "postCreateCommand": "pip install -r requirements.txt && cp .env.example .env",
  "postStartCommand": "echo 'Run: python3 -m geolatent.demo  OR  python3 -m geolatent serve --scenario neutral_baseline --steps 20'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.black-formatter",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["geolatent/tests"],
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },
  "remoteEnv": {
    "GEOLATENT_ALLOW_HEADER_DEV": "true",
    "GEOLATENT_JWT_SECRET": "devcontainer-secret-do-not-use-in-prod",
    "GEOLATENT_AUDIT_SIGNING_KEY": "devcontainer-audit-key",
    "GEOLATENT_BUNDLE_SECRET": "devcontainer-bundle-key"
  }
}
